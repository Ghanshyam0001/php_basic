Route::get('/export-descriptions', [DescriptionExportController::class, 'export']);

<?php

namespace App\Http\Controllers;

use Illuminate\Support\Facades\DB;

class DescriptionExportController extends Controller
{
    public function export()
    {
        $fileName = "descriptions.xls";

        $descriptions = DB::table('descriptions')
            ->select('old_description', 'new_description')
            ->get();

        $headers = [
            "Content-Type" => "application/vnd.ms-excel",
            "Content-Disposition" => "attachment; filename={$fileName}",
            "Pragma" => "no-cache",
            "Cache-Control" => "must-revalidate",
            "Expires" => "0",
        ];

        $content = '
        <table border="1">
            <tr>
                <th>Old Description</th>
                <th>New Description</th>
            </tr>
        ';

        foreach ($descriptions as $description) {

            $content .= '
            <tr>
                <td>' . htmlspecialchars($description->old_description) . '</td>
                <td>' . htmlspecialchars($description->new_description) . '</td>
            </tr>
            ';
        }

        $content .= '</table>';

        return response($content, 200, $headers);
    }
}
